# Ports
NGINX_PORT=8080
ADMINER_PORT=8081
POSTGRES_PORT=5432
REDIS_PORT=6379

# PostgreSQL
POSTGRES_DB=ai_task
POSTGRES_USER=app
POSTGRES_PASSWORD=app
POSTGRES_VERSION=16

# Symfony
APP_ENV=dev
APP_SECRET=changeme
DATABASE_URL="postgresql://app:app@postgres:5432/ai_task?serverVersion=16&charset=utf8"
REDIS_URL="redis://redis:6379"

# Integrations
TELEGRAM_BOT_TOKEN=

# С v2 whitelist хранится в БД (users.is_allowed). Эта переменная нужна
# ТОЛЬКО для bootstrap-миграции Version20260428000000 — она апгрейдит
# перечисленных тут пользователей до allowed=true. После первой выкатки
# переменную можно оставить пустой (или удалить) — управление доступом
# идёт через /admin invite/approve в самом боте.
TELEGRAM_ALLOWED_USER_IDS=

# Telegram ID администратора. Один человек, имеет доступ к /admin commands
# (requests / users / invite / revoke). Whitelist auto-grant'ится при
# первом обращении (см. AccessGate::isAllowed).
ADMIN_TELEGRAM_ID=
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL_PARSER=claude-haiku-4-5
ANTHROPIC_MODEL_ADVISOR=claude-sonnet-4-6
ANTHROPIC_MODEL_ASSISTANT=claude-sonnet-4-6

# Telegram режим работы:
#   polling — long-polling через bot-сервис (BotRunCommand). Локалка/dev.
#   webhook — Telegram POST'ит на /api/telegram/webhook/<secret>. Prod.
TELEGRAM_MODE=polling

# Случайный ≥32 символа secret для webhook (часть URL + X-Telegram-Bot-Api-Secret-Token).
# Генерация: openssl rand -hex 16  →  даст 32 hex-символа.
# Не нужен для polling; в docker-compose.prod.yml — обязателен.
TELEGRAM_WEBHOOK_SECRET=

# Prod-only: домен для Caddy/Let's Encrypt. Используется в Caddyfile и в URL вебхука.
DOMAIN=
